# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://template_nest:template_nest@localhost:5432/template_nest?schema=public

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3001

# Logging
PINO_LOG_LEVEL=info

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
