# Application
NODE_ENV=development
PORT=3002

# Todoist
TODOIST_API_TOKEN=your_todoist_api_token_here

# Cache
CACHE_TTL_SECONDS=300

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3002,https://tasks.fmarcos.dev

# Logging
PINO_LOG_LEVEL=info

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100